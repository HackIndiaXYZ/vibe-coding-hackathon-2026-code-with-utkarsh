# ============================================
# PRANAI - Complete .gitignore
# ============================================

# -------------------- Secrets & API Keys --------------------
# CRITICAL - NEVER commit these!
lib/constants/api_keys.dart
.env
.env.local
.env.production
*.key
*.pem
*.p8
*.p12
*.pem

# -------------------- Firebase --------------------
# Firebase configuration files (contains secrets)
google-services.json
GoogleService-Info.plist
firebase_options.dart
.firebase/

# -------------------- Flutter/Dart --------------------
# Flutter generated files
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/

# iOS
ios/Pods/
ios/.symlinks/
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/Podfile.lock

# Android
android/.gradle/
android/app/.cxx/
android/app/debug/
android/app/profile/
android/app/release/
android/local.properties

# Web
web/index.html.bak
web/*.dill

# Linux
linux/flutter/ephemeral/

# Windows
windows/flutter/ephemeral/

# macOS
macos/Flutter/ephemeral/

# -------------------- IDE --------------------
# Android Studio / IntelliJ
.idea/
*.iml
*.ipr
*.iws

# VS Code
.vscode/
*.code-workspace

# -------------------- OS Generated Files --------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.directory-*
.directory-*-*
*~

# -------------------- Logs --------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# -------------------- Build Outputs --------------------
build/
dist/
out/
bin/
*.o
*.a
*.so

# -------------------- Temporary Files --------------------
*.tmp
*.temp
*.cache
*.swp
*.swo
*~

# -------------------- Testing --------------------
*.test.dart
coverage/
test/.test_config.dart

# -------------------- Dependency Directories --------------------
node_modules/
jspm_packages/
web_modules/

# -------------------- Package Manager --------------------
.pnpm-store
.yarn-integrity

# -------------------- Environment Variables --------------------
.env
.env.*
!.env.example

# -------------------- Assets Cache --------------------
assets/cache/
assets/generated/

# -------------------- Backup Files --------------------
*.bak
*.backup
*.old

# -------------------- Archive Files --------------------
*.zip
*.tar.gz
*.rar
*.7z

# -------------------- Database Files --------------------
*.db
*.sqlite
*.sqlite3

# -------------------- Certificate Files --------------------
*.crt
*.cer
*.der
*.p7b
*.p7c
